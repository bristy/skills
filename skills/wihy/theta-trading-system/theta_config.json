{
  "name": "theta-trading-system",
  "version": "1.0.0",
  "description": "基于真实A股涨停股数据的智能选股系统",
  "author": "Theta Team",
  "license": "MIT",
  "tags": ["A股", "量化交易", "机器学习", "涨停股", "选股"],
  "requirements": {
    "python": ">=3.8",
    "packages": [
      "akshare>=1.12.0",
      "pandas>=1.3.0",
      "numpy>=1.21.0",
      "scikit-learn>=1.0.0"
    ]
  },
  "config": {
    "risk_control": {
      "max_position": 0.2,
      "total_position": 0.6,
      "stop_loss": 0.05,
      "take_profit_1": 0.10,
      "take_profit_2": 0.15
    },
    "scoring_weights": {
      "technical": 0.4,
      "capital": 0.3,
      "fundamental": 0.2,
      "sentiment": 0.1
    },
    "update_schedule": "0 15:30 * * 1-5"
  },
  "scripts": {
    "daily_update": "scripts/daily_data_update.py",
    "train_model": "scripts/train_with_real_data_v2.py",
    "analyze": "scripts/theta_analyzer.py"
  },
  "data": {
    "database": "data/real_stock_data.db",
    "model": "models/theta_final/theta_model.pkl"
  }
}
